# OpenClaw Config Editor — Environment Configuration

# OpenClaw installation path (where openclaw.json lives)
OPENCLAW_HOME=C:\Users\YourName\.openclaw

# OpenClaw config file path
OPENCLAW_CONFIG_PATH=C:\Users\YourName\.openclaw\openclaw.json

# Claude Code skills directory (optional, for skill discovery)
CLAUDE_SKILLS_PATH=C:\Users\YourName\.claude\skills

# OpenClaw skills directory (optional, for skill discovery)
OPENCLAW_SKILLS_PATH=C:\Users\YourName\.openclaw\skills

# Server port (default: 3001)
SERVER_PORT=3001

# Enable API key masking in UI (default: true)
MASK_API_KEYS=true

# Number of backup copies to keep (default: 5)
MAX_BACKUPS=5
